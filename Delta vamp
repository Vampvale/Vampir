-- Fungsi UI
local function createToggle(parent, name, yPos, getFunc, setFunc, btnWidth)
    btnWidth = btnWidth or 45
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -20, 0, 30)
    bg.Position = UDim2.new(0, 10, 0, yPos)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 18
    label.Parent = bg
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, btnWidth, 0, 24)
    btn.Position = UDim2.new(1, -btnWidth-10, 0.5, -12)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.BorderColor3 = Color3.fromRGB(180, 0, 0)
    btn.Text = "OFF"
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    btn.Parent = bg
    
    btn.MouseButton1Click:Connect(function()
        local newState = not getFunc()
        setFunc(newState)
        btn.Text = newState and "ON" or "OFF"
        btn.BackgroundColor3 = newState and Color3.fromRGB(180, 0, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

local function createSlider(parent, name, yPos, minVal, maxVal, defaultVal, getFunc, setFunc, valueSuffix, decimals)
    decimals = decimals or 1
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -20, 0, 50)
    bg.Position = UDim2.new(0, 10, 0, yPos)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 25)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 18
    label.Parent = bg
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 60, 0, 25)
    valueLabel.Position = UDim2.new(1, -70, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(defaultVal) .. (valueSuffix or "")
    valueLabel.TextColor3 = Color3.fromRGB(180, 0, 0)
    valueLabel.Font = Enum.Font.SourceSansBold
    valueLabel.TextSize = 18
    valueLabel.Parent = bg
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -30, 0, 6)
    sliderBg.Position = UDim2.new(0, 0, 0, 30)
    sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = bg
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg
    
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(0, 16, 0, 16)
    sliderBtn.Position = UDim2.new((defaultVal - minVal) / (maxVal - minVal), -8, 0.5, -8)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.BorderSizePixel = 1
    sliderBtn.BorderColor3 = Color3.fromRGB(180, 0, 0)
    sliderBtn.Text = ""
    sliderBtn.Parent = sliderBg
    
    local dragging = false
    local mouse = player:GetMouse()
    
    sliderBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    mouse.Move:Connect(function()
        if dragging then
            local pos = mouse.X - sliderBg.AbsolutePosition.X
            local percent = math.clamp(pos / sliderBg.AbsoluteSize.X, 0, 1)
            local value = minVal + (maxVal - minVal) * percent
            local mult = 10^decimals
            value = math.floor(value * mult + 0.5) / mult
            sliderFill.Size = UDim2.new(percent, 0, 1, 0)
            sliderBtn.Position = UDim2.new(percent, -8, 0.5, -8)
            valueLabel.Text = tostring(value) .. (valueSuffix or "")
            setFunc(value)
        end
    end)
    
    mouse.Button1Up:Connect(function()
        dragging = false
    end)
    
    setFunc(defaultVal)
end

-- Update konten berdasarkan tab
function updateContent()
    for _, child in pairs(contentContainer:GetChildren()) do
        child:Destroy()
    end
    
    local yPos = 10
    
    if activeTab == "COMBAT" then
        createToggle(contentContainer, "Kill Aura", yPos, 
            function() return features.killAura end, 
            function(v) features.killAura = v end)
        yPos = yPos + 40
        createSlider(contentContainer, "Damage Multiplier", yPos, 1, 50, features.dmgMult,
            function() return features.dmgMult end,
            function(v) features.dmgMult = v end, "x")
        yPos = yPos + 60
    elseif activeTab == "MOVEMENT" then
        createToggle(contentContainer, "Speed Boost", yPos,
            function() return features.speedBoost end,
            function(v) features.speedBoost = v end)
        yPos = yPos + 40
        createSlider(contentContainer, "Walk Speed", yPos, 16, 250, features.speedValue,
            function() return features.speedValue end,
            function(v) features.speedValue = v end, "")
        yPos = yPos + 60
        createToggle(contentContainer, "Jump Boost", yPos,
            function() return features.jumpBoost end,
            function(v) features.jumpBoost = v end)
        yPos = yPos + 40
        createSlider(contentContainer, "Jump Power", yPos, 50, 500, features.jumpPower,
            function() return features.jumpPower end,
            function(v) features.jumpPower = v end, "")
        yPos = yPos + 60
        createToggle(contentContainer, "Infinite Jump", yPos,
            function() return features.infJump end,
            function(v) features.infJump = v end)
        yPos = yPos + 40
    elseif activeTab == "HITBOX" then
        createToggle(contentContainer, "Big Hitbox (Musuh)", yPos,
            function() return features.hitboxEnabled end,
            function(v) features.hitboxEnabled = v end)
        yPos = yPos + 40
        createSlider(contentContainer, "Hitbox Scale", yPos, 1, 5, features.hitboxScale,
            function() return features.hitboxScale end,
            function(v) features.hitboxScale = v end, "x", 1)
        yPos = yPos + 60
        createToggle(contentContainer, "Transparent Hitbox", yPos,
            function() return features.hitboxTransparent end,
            function(v) features.hitboxTransparent = v end, 60)
        yPos = yPos + 40
    elseif activeTab == "VISUALS" then
        createToggle(contentContainer, "ESP (Nama + Health)", yPos,
            function() return features.espOn end,
            function(v) features.espOn = v end)
        yPos = yPos + 40
        createToggle(contentContainer, "Wallhack (Tembus Dinding)", yPos,
            function() return features.wallhackOn end,
            function(v) features.wallhackOn = v end)
        yPos = yPos + 40
    end
end

updateContent()

