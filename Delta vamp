local userInput = game:GetService("UserInputService")
local jumpConnection
function enableInfJump(enable)
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
    if enable then
        jumpConnection = userInput.JumpRequest:Connect(function()
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid:ChangeState("Jumping")
            end
        end)
    end
end
spawn(function()
    while true do
        wait(0.3)
        enableInfJump(features.infJump)
    end
end)

spawn(function()
    while true do
        wait(0.3)
        if features.killAura and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local root = player.Character.HumanoidRootPart
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") then
                    local otherRoot = p.Character:FindFirstChild("HumanoidRootPart")
                    if otherRoot and (root.Position - otherRoot.Position).magnitude < 20 then
                        p.Character.Humanoid.Health = p.Character.Humanoid.Health - (12 * features.dmgMult)
                    end
                end
            end
        end
    end
end)

spawn(function()
    while true do
        wait(0.3)
        if features.hitboxEnabled then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local scale = features.hitboxScale
                    local parts = {
                        p.Character:FindFirstChild("Head"),
                        p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("UpperTorso"),
                        p.Character:FindFirstChild("HumanoidRootPart"),
                        p.Character:FindFirstChild("Left Arm") or p.Character:FindFirstChild("LeftHand"),
                        p.Character:FindFirstChild("Right Arm") or p.Character:FindFirstChild("RightHand"),
                        p.Character:FindFirstChild("Left Leg") or p.Character:FindFirstChild("LeftFoot"),
                        p.Character:FindFirstChild("Right Leg") or p.Character:FindFirstChild("RightFoot")
                    }
                    for _, part in pairs(parts) do
                        if part and part:IsA("BasePart") then
                            if not part:GetAttribute("OriginalSize") then
                                part:SetAttribute("OriginalSize", part.Size)
                            end
                            part.Size = part:GetAttribute("OriginalSize") * scale
                            part.Transparency = features.hitboxTransparent and 0.7 or 0
                        end
                    end
                end
            end
        else
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local parts = {
                        p.Character:FindFirstChild("Head"),
                        p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("UpperTorso"),
                        p.Character:FindFirstChild("HumanoidRootPart"),
                        p.Character:FindFirstChild("Left Arm") or p.Character:FindFirstChild("LeftHand"),
                        p.Character:FindFirstChild("Right Arm") or p.Character:FindFirstChild("RightHand"),
                        p.Character:FindFirstChild("Left Leg") or p.Character:FindFirstChild("LeftFoot"),
                        p.Character:FindFirstChild("Right Leg") or p.Character:FindFirstChild("RightFoot")
                    }
                    for _, part in pairs(parts) do
                        if part and part:IsA("BasePart") and part:GetAttribute("OriginalSize") then
                            part.Size = part:GetAttribute("OriginalSize")
                            part.Transparency = 0
                        end
                    end
                end
            end
        end
    end
end)

