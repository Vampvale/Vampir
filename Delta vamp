local function createTabButton(name, icon, index)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 150, 0, 35)
    btn.Position = UDim2.new(0, (index-1)*160, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = icon .. " " .. name
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.Font = Enum.Font.GothamBold
    btn.TextScaled = true
    btn.BorderColor3 = Color3.fromRGB(180, 0, 0)
    btn.BorderSizePixel = 1
    btn.Parent = tabBar
    
    btn.MouseButton1Click:Connect(function()
        for _, b in pairs(tabButtons) do
            b.btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            b.btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        btn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        activeTab = name
        updateContent()
    end)
    
    table.insert(tabButtons, {btn = btn, name = name})
end

for i, tab in ipairs(tabs) do
    createTabButton(tab.name, tab.icon, i)
end
